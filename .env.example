# Google Gemini API Key - Get it from https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_api_key_here

# Serper API Key for web search - Get it from https://serper.dev/
SERPER_API=your_serper_api_key_here

# Firecrawl API Key for web scraping - Get it from https://www.firecrawl.dev/
FIRECRAWL_API=your_firecrawl_api_key_here

# Path to Tesseract OCR executable (Windows example below)
TESSERACT_CMD_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
